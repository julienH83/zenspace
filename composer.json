{
    "name": "zenspace/reservation-prestations",
    "description": "ZenSpace — plateforme de réservation de prestations bien-être (PHP MVC, MySQL, MongoDB).",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-mongodb": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/app/"
        },
        "files": [
            "src/app/Core/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "find src -name '*.php' -print0 | xargs -0 -n1 php -l"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
