# Variables d'environnement de l'application.
# Copier ce fichier en « .env » et adapter les valeurs si besoin.

# Environnement : "dev" (affiche les erreurs) ou "prod" (les masque).
APP_ENV=dev
APP_NAME=ZenSpace
APP_URL=http://localhost:8080

# --- Base de données relationnelle (MySQL) ---
# En production : utiliser un compte DÉDIÉ à privilèges réduits (SELECT/INSERT/
# UPDATE/DELETE uniquement), JAMAIS root. Voir db/migrations/2026_06_01_hardening.sql.
DB_HOST=mysql
DB_PORT=3306
DB_NAME=zenspace
DB_USER=zenspace_app
DB_PASS=change-moi-mot-de-passe-app

# --- Base non relationnelle (MongoDB) ---
MONGO_URI=mongodb://mongo:27017
MONGO_DB=zenspace_stats

# --- Cache / rate-limiting (Redis, optionnel) ---
# RATE_LIMIT_DRIVER : "file" (par défaut, sans dépendance) ou "redis" (production).
RATE_LIMIT_DRIVER=file
REDIS_URL=tcp://redis:6379

# --- E-mails ---
# MAIL_TRANSPORT : "log" (écrit dans storage/mail/*.eml, idéal en dev) ou "mail"
# (fonction mail() de PHP / relais SMTP en production).
MAIL_TRANSPORT=log
MAIL_FROM=no-reply@zenspace.fr

# --- Sécurité ---
# Clé secrète (signature de jetons, QR de réservation…). En prod : longue, aléatoire, secrète.
APP_SECRET=change-moi-par-une-longue-chaine-aleatoire

# --- Paiement (Stripe, scaffold §4.4) ---
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLIC=
