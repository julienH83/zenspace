# Variables d'environnement de l'application.
# Copier ce fichier en « .env » et adapter les valeurs si besoin.

# Environnement : "dev" (affiche les erreurs) ou "prod" (les masque).
APP_ENV=dev
APP_NAME=ZenSpace
APP_URL=http://localhost:8080

# --- Base de données relationnelle (MySQL) ---
DB_HOST=mysql
DB_PORT=3306
DB_NAME=zenspace
DB_USER=root
DB_PASS=root

# --- Base non relationnelle (MongoDB) ---
MONGO_URI=mongodb://mongo:27017
MONGO_DB=zenspace_stats

# --- Sécurité ---
# Clé secrète utilisée pour signer les jetons (réinitialisation de mot de passe).
APP_SECRET=change-moi-par-une-longue-chaine-aleatoire
